{
  "name": "tabularcraft",
  "displayName": "Tabularcraft",
  "description": "Manage Azure Analysis Services tabular models from VS Code",
  "version": "0.1.5",
  "publisher": "maersk-pda",
  "icon": "resources/icon.png",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulo-ah/tabularcraft.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["Azure Analysis Services", "AAS", "TOM", "XMLA", "DAX", "tabular"],
  "activationEvents": [
    "onView:tabularcraft.modelTree",
    "onCommand:tabularcraft.addConnection",
    "onCommand:tabularcraft.disconnect",
    "onCommand:tabularcraft.refreshTree",
    "onCommand:tabularcraft.processDatabase",
    "onCommand:tabularcraft.processTable",
    "onCommand:tabularcraft.processPartition",
    "onCommand:tabularcraft.processAdd",
    "onCommand:tabularcraft.openPartitionQuery",
    "onCommand:tabularcraft.openMeasureEditor",
    "onCommand:tabularcraft.createNewMeasure",
    "onCommand:tabularcraft.createNewDataColumn",
    "onCommand:tabularcraft.createNewCalculatedColumn",
    "onCommand:tabularcraft.connectionNodeConnect",
    "onCommand:tabularcraft.connectionNodeEdit",
    "onCommand:tabularcraft.connectionNodeDelete",
    "onCommand:tabularcraft.renameObject",
    "onCommand:tabularcraft.deleteObject",
    "onCommand:tabularcraft.openProperties",
    "onCommand:tabularcraft.openTmslConsole"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tabularcraft.addConnection",
        "title": "Add Connection",
        "category": "Tabularcraft",
        "icon": "$(add)"
      },
      {
        "command": "tabularcraft.disconnect",
        "title": "Disconnect",
        "category": "Tabularcraft",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "tabularcraft.refreshTree",
        "title": "Refresh",
        "category": "Tabularcraft",
        "icon": "$(refresh)"
      },
      {
        "command": "tabularcraft.processDatabase",
        "title": "Process Database (Full)",
        "category": "Tabularcraft",
        "icon": "$(run-all)"
      },
      {
        "command": "tabularcraft.processTable",
        "title": "Process Table (Full)",
        "category": "Tabularcraft",
        "icon": "$(run)"
      },
      {
        "command": "tabularcraft.processPartition",
        "title": "Process Partition (Full)",
        "category": "Tabularcraft",
        "icon": "$(run)"
      },
      {
        "command": "tabularcraft.processAdd",
        "title": "ProcessAdd (Incremental, TMSL)",
        "category": "Tabularcraft",
        "icon": "$(add)"
      },
      {
        "command": "tabularcraft.openPartitionQuery",
        "title": "Open Partition Query",
        "category": "Tabularcraft",
        "icon": "$(code)"
      },
      {
        "command": "tabularcraft.openMeasureEditor",
        "title": "Open Measure Editor",
        "category": "Tabularcraft",
        "icon": "$(symbol-function)"
      },
      {
        "command": "tabularcraft.createNewMeasure",
        "title": "Create New Measure",
        "category": "Tabularcraft",
        "icon": "$(add)"
      },
      {
        "command": "tabularcraft.createNewDataColumn",
        "title": "Create New Data Column",
        "category": "Tabularcraft",
        "icon": "$(add)"
      },
      {
        "command": "tabularcraft.createNewCalculatedColumn",
        "title": "Create New Calculated Column",
        "category": "Tabularcraft",
        "icon": "$(symbol-field)"
      },
      {
        "command": "tabularcraft.connectionNodeConnect",
        "title": "Connect",
        "category": "Tabularcraft",
        "icon": "$(plug)"
      },
      {
        "command": "tabularcraft.connectionNodeEdit",
        "title": "Edit Connection",
        "category": "Tabularcraft",
        "icon": "$(edit)"
      },
      {
        "command": "tabularcraft.connectionNodeDelete",
        "title": "Delete Connection",
        "category": "Tabularcraft",
        "icon": "$(trash)"
      },
      {
        "command": "tabularcraft.renameObject",
        "title": "Rename",
        "category": "Tabularcraft",
        "icon": "$(edit)"
      },
      {
        "command": "tabularcraft.deleteObject",
        "title": "Delete",
        "category": "Tabularcraft",
        "icon": "$(trash)"
      },
      {
        "command": "tabularcraft.openProperties",
        "title": "Open Properties",
        "category": "Tabularcraft",
        "icon": "$(list-selection)"
      },
      {
        "command": "tabularcraft.openTmslConsole",
        "title": "Open TMSL Console",
        "category": "Tabularcraft",
        "icon": "$(terminal)"
      }
    ],
    "views": {
      "tabularcraft-panel": [
        {
          "id": "tabularcraft.modelTree",
          "name": "Model",
          "when": "true"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tabularcraft-panel",
          "title": "Tabularcraft",
          "icon": "resources/activitybar-icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "tabularcraft.addConnection",
          "when": "view == tabularcraft.modelTree",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.disconnect",
          "when": "view == tabularcraft.modelTree && tabularcraft.connected",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.refreshTree",
          "when": "view == tabularcraft.modelTree && tabularcraft.connected",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.openTmslConsole",
          "when": "view == tabularcraft.modelTree && tabularcraft.connected",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tabularcraft.processDatabase",
          "when": "view == tabularcraft.modelTree && viewItem == database",
          "group": "process"
        },
        {
          "command": "tabularcraft.processTable",
          "when": "view == tabularcraft.modelTree && viewItem == table",
          "group": "process"
        },
        {
          "command": "tabularcraft.openMeasureEditor",
          "when": "view == tabularcraft.modelTree && viewItem == table",
          "group": "measures"
        },
        {
          "command": "tabularcraft.createNewMeasure",
          "when": "view == tabularcraft.modelTree && viewItem == measures-group",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.createNewDataColumn",
          "when": "view == tabularcraft.modelTree && viewItem == columns-group",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.createNewCalculatedColumn",
          "when": "view == tabularcraft.modelTree && viewItem == columns-group",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.processPartition",
          "when": "view == tabularcraft.modelTree && viewItem == partition",
          "group": "process"
        },
        {
          "command": "tabularcraft.processAdd",
          "when": "view == tabularcraft.modelTree && viewItem == partition",
          "group": "process"
        },
        {
          "command": "tabularcraft.openPartitionQuery",
          "when": "view == tabularcraft.modelTree && viewItem == partition",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.renameObject",
          "when": "view == tabularcraft.modelTree && (viewItem == database || viewItem == table || viewItem == column || viewItem == measure || viewItem == hierarchy || viewItem == level || viewItem == partition || viewItem == role || viewItem == perspective || viewItem == data-source || viewItem == culture)",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.deleteObject",
          "when": "view == tabularcraft.modelTree && (viewItem == column || viewItem == measure)",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.connectionNodeConnect",
          "when": "view == tabularcraft.modelTree && viewItem == connection-profile",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.connectionNodeEdit",
          "when": "view == tabularcraft.modelTree && viewItem == connection-profile",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.connectionNodeDelete",
          "when": "view == tabularcraft.modelTree && viewItem == connection-profile",
          "group": "navigation"
        },
        {
          "command": "tabularcraft.openProperties",
          "when": "view == tabularcraft.modelTree && (viewItem == database || viewItem == table || viewItem == column || viewItem == measure || viewItem == hierarchy || viewItem == level || viewItem == partition || viewItem == role || viewItem == perspective || viewItem == relationship || viewItem == data-source || viewItem == culture)",
          "group": "navigation@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tabularcraft.renameObject",
        "key": "f2",
        "when": "view == tabularcraft.modelTree && tabularcraft.connected && (viewItem == database || viewItem == table || viewItem == column || viewItem == measure || viewItem == hierarchy || viewItem == level || viewItem == partition || viewItem == role || viewItem == perspective || viewItem == data-source || viewItem == culture)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run prepare-sidecar && npm run compile",
    "prepare-sidecar": "node ./scripts/prepare-sidecar.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
